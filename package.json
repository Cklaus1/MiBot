{
  "name": "mibot",
  "version": "0.1.0",
  "description": "AI meeting bot — joins your calls, records audio, transcribes via AudioScript",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mibot": "dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "playwright": "^1.50.0",
    "puppeteer": "^24.40.0",
    "puppeteer-stream": "^3.0.22"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.15.15",
    "tsup": "^8.5.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=20"
  }
}
